{
  "name": "lotato",
  "version": "0.2.0-rc.1",
  "description": "On-firmware MeshCore ingestor for Potato Mesh",
  "keywords": ["meshcore", "lotato", "esp32", "ingest", "potato"],
  "authors": [{ "name": "MeshEnvy", "maintainer": true }],
  "license": "MIT",
  "homepage": "https://github.com/MeshEnvy/mesh-forge",
  "repository": {
    "type": "git",
    "url": "https://github.com/MeshEnvy/mesh-forge.git"
  },
  "frameworks": ["arduino"],
  "platforms": ["espressif32"],
  "dependencies": [{ "name": "lo-star", "version": "symlink://../lo-star" }],
  "build": {
    "libArchive": false,
    "srcDir": ".",
    "srcFilter": [
      "+<*.cpp>",
      "+<*.c>"
    ],
    "extraScript": "extra_script.py"
  }
}
